---
export interface Props {
	title: string;
	body: string;
	href: string;
}

const { href, title, body } = Astro.props;
---

<li class="list-none">
	<a
		href={href}
		class="group block h-full rounded-3xl border border-slate-200 bg-white/80 p-6 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-violet-300 hover:shadow-xl hover:shadow-violet-100 dark:border-slate-800 dark:bg-slate-900/80 dark:hover:shadow-violet-950/40"
	>
		<h2 class="flex items-center justify-between text-xl font-bold text-slate-950 dark:text-white">
			{title}
			<span class="transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">&rarr;</span>
		</h2>
		<p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-300">{body}</p>
	</a>
</li>
