---
import { Toaster } from "vue-sonner";
import { defaultLocale, getAlternateLinks, type Locale } from "../i18n";
import "../styles/global.css";

export interface Props {
	title: string;
	description?: string;
	locale?: Locale;
	path?: string;
	enableToaster?: boolean;
}

const {
	title,
	description = "",
	locale = defaultLocale,
	path = Astro.url.pathname,
	enableToaster = false,
} = Astro.props;
const alternateLinks = getAlternateLinks(path).map(({ locale: hrefLang, href }) => ({
	hrefLang,
	href: new URL(href, Astro.url.origin).href,
}));
const canonicalUrl = new URL(path, Astro.url.origin);
---

<!doctype html>
<html lang={locale}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="referrer" content="strict-origin-when-cross-origin" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="canonical" href={canonicalUrl.href} />
		{alternateLinks.map(({ hrefLang, href }) => <link rel="alternate" hreflang={hrefLang} href={href} />)}
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		{enableToaster ? <Toaster client:idle richColors expand position="top-right" /> : null}
		<slot />
	</body>
</html>
