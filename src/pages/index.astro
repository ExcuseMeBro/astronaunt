---
import Card from "../components/Card.astro";
import { localizePath, type Locale, useTranslations } from "../i18n";
import Layout from "../layouts/Layout.astro";

type HomeCard = {
	href: string;
	title: string;
	body: string;
};

const locale: Locale = "en";
const { text, raw } = useTranslations(locale);
const cards = raw<HomeCard[]>("home.cards", []);
---

<Layout
	title={text("home.metaTitle")}
	description={text("site.description")}
	locale={locale}
	path="/"
>
	<main class="mx-auto flex min-h-screen max-w-5xl flex-col justify-center px-6 py-16">
		<section class="max-w-3xl space-y-6">
			<p class="text-sm font-semibold uppercase tracking-[0.3em] text-violet-600">{text("site.title")}</p>
			<h1 class="text-5xl font-black tracking-tight text-slate-950 sm:text-7xl dark:text-white">
				{text("home.title")}
			</h1>
			<p class="text-lg leading-8 text-slate-700 dark:text-slate-300">
				{text("home.subtitleLead")} <strong>{text("home.subtitleStrong")}</strong>{" "}
				{text("home.subtitleMiddle")} <a class="font-semibold text-violet-600 underline underline-offset-4" href="https://www.remotion.dev/">{text("home.subtitleLink")}</a>{text("home.subtitleEnd")}
			</p>
			<div class="flex flex-wrap gap-3">
				<a class="btn btn-primary" href={localizePath(locale, "/demo")}>{text("home.ctaPrimary")}</a>
				<a class="btn btn-outline" href="https://github.com/ExcuseMeBro/astronaunt#readme">{text("home.ctaSecondary")}</a>
			</div>
		</section>

		<ul role="list" class="mt-12 grid gap-4 p-0 sm:grid-cols-2">
			{cards.map((card) => <Card {...card} />)}
		</ul>
	</main>
</Layout>
